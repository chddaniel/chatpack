    "@chatpack/core": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.1",
    "@types/pg": "^8.15.4",
    "typescript": "^5.7.2"
  }
}
